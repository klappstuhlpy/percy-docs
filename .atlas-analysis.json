  "keyFeatures": [
    "Hybrid slash and prefix commands (every command works as both /command and ?command)",
    "Full moderation suite: kick, ban, mute, tempban, slowmode, purge, lockdown",
    "AutoMod with raid protection, spam detection, and mention-spam auto-ban",
    "Captcha Sentinel: verification system to block bot accounts and raiders",
    "Economy system: wallet/banking, daily rewards, shop, fishing, hunting, lottery",
    "Casino games: Blackjack, Texas Hold'em Poker, Roulette, Slots, Tower, and more",
    "Lavalink-powered music player with Spotify, Apple Music, SoundCloud support",
    "Playlists, 24/7 mode, radio presets, audio filters, lyrics with sync",
    "Server leveling with XP, rank cards, leaderboards, level roles, and voice XP",
    "Community tools: polls, giveaways, highlights, tags, role menus",
    "Utility: reminders, autoresponder, temporary voice channels, translations",
    "Per-user privacy controls (GDPR-compliant data export and deletion)"
  ],
  "publicApiSurface": [
